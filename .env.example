# --- 模型服务配置 (OpenAI 兼容协议) ---
LLM_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-key
OPENAI_API_BASE=https://api.deepseek.com/v1
# Optional purpose split without router config:
# CHAT_LLM_MODEL=grok-4.20-fast,qwen-3-235b-a22b-instruct-2507
# INGEST_LLM_MODEL=LongCat-Flash-Chat,qwen-3-235b-a22b-instruct-2507
# CHAT_LLM_API_BASE=http://gateway.example.com/v1
# INGEST_LLM_API_BASE=http://gateway.example.com/v1
# Optional structured router config:
# Deployments inherit LLM_API_BASE/LLM_API_KEY or OPENAI_API_BASE/OPENAI_API_KEY unless overridden in JSON.
# LLM_ROUTER_CONFIG_FILE=./llm_router.json
# LLM_ROUTER_STATS_INTERVAL=20

# 时区（容器与应用统一）
TZ=Asia/Shanghai
APP_TIMEZONE=Asia/Shanghai
# Structured router 当前默认建议单 worker，避免进程间状态分裂。
# GUNICORN_WORKERS=1
API_PUBLIC_PORT=8005
QDRANT_PUBLIC_PORT=6333
API_IMAGE_TAG=llama-embedding

# Embedding / Rerank
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk-your-key
EMBEDDING_API_BASE=https://api.deepseek.com/v1
EMBEDDING_DIM=1536
EMBEDDING_TIMEOUT=60
EMBEDDING_CONCURRENCY=2
EMBEDDING_REQUEST_BATCH_SIZE=4
EMBEDDING_MAX_INPUT_TOKENS=
EMBEDDING_QUERY_PREFIX=
EMBEDDING_DOCUMENT_PREFIX=
SPARSE_TOP_K=12
# Rerank 走 OpenAI 标准 /v1/chat/completions（填写基础地址即可）
RERANK_API_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=sk-your-rerank-key
RERANK_MODEL=Qwen/Qwen3-Reranker-4B
RERANK_TIMEOUT=180

# Qdrant (set QDRANT_URL + QDRANT_API_KEY when using managed clusters)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_HTTPS=false
QDRANT_URL=
QDRANT_API_KEY=
COLLECTION_NAME=financial_reports

# 策略参数
TOP_K_RETRIEVAL=100
TOP_N_RERANK=20
FINAL_TOP_K=10
TIME_DECAY_RATE=0.005

# --- FastEmbed 本地缓存 (仅需 Sparse 模型) ---
FASTEMBED_CACHE_PATH=./model_cache
FASTEMBED_SPARSE_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions
INSERT_BATCH_SIZE=8
DOCUMENT_LIST_COUNT_CONCURRENCY=16
DOCUMENT_LIST_MAX_POINTS_TO_SCAN=50000

# --- 自托管 llama.cpp Embedding（可选，需搭配 docker-compose.llama-embedding.yml） ---
EMBEDDING_PUBLIC_PORT=18083
EMBEDDING_GGUF_HOST_PATH=./embedding-models/gguf-jina-v5
EMBEDDING_GGUF_FILE=v5-small-retrieval-F16.gguf
EMBEDDING_CONTEXT_WINDOW=8192
EMBEDDING_SERVER_BATCH=1024
EMBEDDING_SERVER_PARALLEL=2
EMBEDDING_UBATCH=1024
EMBEDDING_THREADS_BATCH=8
EMBEDDING_MAX_INPUT_TOKENS=3500
SELF_HOSTED_EMBEDDING_MODEL=jina-embeddings-v5-text-small-retrieval
SELF_HOSTED_EMBEDDING_DIM=1024
EMBEDDING_COLLECTION_NAME=financial_reports_jina_v5_1024
# Jina retrieval 建议启用以下前缀；开启后会自动走兼容客户端
EMBEDDING_QUERY_PREFIX=Query:
EMBEDDING_DOCUMENT_PREFIX=Document:
